<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_live_monitoring_tree" model="ir.ui.view">
        <field name="name">asset.live.monitoring.tree</field>
        <field name="model">asset.live.monitoring</field>
        <field name="arch" type="xml">
            <list>
                <field name="asset_id"/>
                <field name="serial_number"/>
                <field name="heartbeat"/>
                <field name="is_online"/>
                <field name="cpu_usage_percent"/>
                <field name="ram_usage_percent"/>
                <field name="disk_usage_percent"/>
                <field name="battery_percentage"/>
                <field name="network_upload_mbps"/>
                <field name="network_download_mbps"/>
                <field name="location_city" optional="show"/>
                <field name="location_state" optional="show"/>
                <field name="location_country" optional="show"/>
                <field name="location_address" optional="hide"/>
                <field name="uptime"/>
                <field name="recording_status"/>
                <field name="ip_address"/>
            </list>
        </field>
    </record>

    <record id="view_asset_live_monitoring_form" model="ir.ui.view">
        <field name="name">asset.live.monitoring.form</field>
        <field name="model">asset.live.monitoring</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Device Info">
                            <field name="asset_id"/>
                            <field name="serial_number"/>
                            <field name="heartbeat"/>
                            <field name="is_online"/>
                            <field name="ip_address"/>
                        </group>
                        <group string="Performance Metrics">
                            <field name="cpu_usage_percent"/>
                            <field name="ram_usage_percent"/>
                            <field name="disk_usage_percent"/>
                            <field name="battery_percentage"/>
                            <field name="battery_health"/>
                        </group>
                    </group>
                    <group>
                        <group string="Network">
                            <field name="network_upload_mbps"/>
                            <field name="network_download_mbps"/>
                            <field name="network_bandwidth"/>
                        </group>
                        <group string="Location Details">
                            <field name="location_address"/>
                            <field name="location_area"/>
                            <field name="location_city"/>
                            <field name="location_state"/>
                            <field name="location_country"/>
                            <label for="latitude" string="Coordinates"/>
                            <div>
                                <field name="latitude" class="oe_inline"/> ,
                                <field name="longitude" class="oe_inline"/>
                            </div>
                            <field name="location_source"/>
                        </group>
                    </group>
                    <group>
                        <group string="Linux">
                            <field name="uptime"/>
                        </group>
                        <group string="CCTV Metrics">
                            <field name="recording_status"/>
                            <field name="motion_detected"/>
                            <field name="last_motion_time"/>
                        </group>
                        <group string="Legacy Fields">
                            <field name="cpu_usage"/>
                            <field name="memory_usage"/>
                            <field name="storage_usage"/>
                            <field name="battery_level"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

     -->

    <record id="action_asset_live_monitoring" model="ir.actions.act_window">
        <field name="name">Live Monitoring</field>
        <field name="res_model">asset.live.monitoring</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_online': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No live monitoring data available
            </p>
            <p>
                This view shows real-time monitoring data from device agents.
                The agent sends metrics every few seconds to keep this data up-to-date.
            </p>
        </field>
    </record>
</odoo>
