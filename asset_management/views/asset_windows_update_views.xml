<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
    Windows Update Management Views
    ================================
    Inherits the existing asset form view to add a Windows Updates tab
    with a premium enterprise dashboard OWL component.
    -->

    <!-- =====================================================
         WINDOWS UPDATE LIST VIEW (Admin/Management)
         ===================================================== -->
    <record id="view_asset_windows_update_list" model="ir.ui.view">
        <field name="name">asset.windows.update.list</field>
        <field name="model">asset.windows.update</field>
        <field name="arch" type="xml">
            <list string="Windows Updates"
                  decoration-success="status == 'installed'"
                  decoration-warning="status == 'installing'"
                  decoration-danger="status == 'blocked'"
                  decoration-muted="status == 'pending'">
                <field name="asset_id"/>
                <field name="kb_number"/>
                <field name="title" optional="show"/>
                <field name="detected_date"/>
                <field name="version"/>
                <field name="severity" widget="badge"
                       decoration-success="severity == 'security'"
                       decoration-danger="severity == 'critical'"
                       decoration-warning="severity == 'important'"
                       decoration-muted="severity == 'optional'"/>
                <field name="size" optional="show"/>
                <field name="status" widget="badge"
                       decoration-success="status in ['installed', 'allowed']"
                       decoration-warning="status == 'installing'"
                       decoration-danger="status in ['blocked', 'failed']"
                       decoration-muted="status == 'pending'"/>
                <field name="action_by" optional="show"/>
                <field name="action_date" optional="show"/>
            </list>
        </field>
    </record>

    <!-- =====================================================
         WINDOWS UPDATE FORM VIEW
         ===================================================== -->
    <record id="view_asset_windows_update_form" model="ir.ui.view">
        <field name="name">asset.windows.update.form</field>
        <field name="model">asset.windows.update</field>
        <field name="arch" type="xml">
            <form string="Windows Update">
                <header>
                    <button name="action_push_update"
                            type="object"
                            string="Push Update"
                            class="btn-primary"
                            invisible="status not in ['pending', 'allowed', 'blocked']"
                            groups="asset_management.group_asset_manager"/>
                    <button name="action_block_update"
                            type="object"
                            string="Block Update"
                            class="btn-danger"
                            invisible="status not in ['pending', 'allowed']"
                            groups="asset_management.group_asset_manager"/>
                    <button name="action_allow_update"
                            type="object"
                            string="Allow Update"
                            class="btn-success"
                            invisible="status != 'blocked'"
                            groups="asset_management.group_asset_manager"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,allowed,installing,installed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="kb_number" placeholder="KB Number..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Update Information">
                            <field name="asset_id"/>
                            <field name="title"/>
                            <field name="detected_date"/>
                            <field name="version"/>
                            <field name="severity"/>
                            <field name="size"/>
                        </group>
                        <group string="Status &amp; Actions">
                            <field name="status"/>
                            <field name="action_by" readonly="1"/>
                            <field name="action_date" readonly="1"/>
                            <field name="is_actionable" readonly="1"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Update description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    
     -->

    <!-- =====================================================
         WINDOWS UPDATE ACTION
         ===================================================== -->
    <record id="action_asset_windows_update" model="ir.actions.act_window">
        <field name="name">Windows Updates</field>
        <field name="res_model">asset.windows.update</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Windows updates detected
            </p>
            <p>
                Windows updates will appear here when detected by the asset agent.
            </p>
        </field>
    </record>

    <!-- =====================================================
         INHERIT ASSET FORM VIEW - ADD WINDOWS UPDATES TAB
         ===================================================== -->
    <record id="view_asset_asset_form_windows_update" model="ir.ui.view">
        <field name="name">asset.asset.form.windows.update</field>
        <field name="model">asset.asset</field>
        <field name="inherit_id" ref="asset_management.view_asset_asset_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Windows Updates" name="windows_updates"
                      groups="asset_management.group_asset_user">
                    <field name="windows_update_ids"
                           widget="windows_update_widget"
                           nolabel="1"
                           style="width: 100%; display: block;"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>