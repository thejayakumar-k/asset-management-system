<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- All Assets Selection Wizard Form View - Full Screen -->
    <record id="view_all_assets_wizard_form" model="ir.ui.view">
        <field name="name">asset.all.assets.wizard.form</field>
        <field name="model">asset.all.assets.wizard</field>
        <field name="arch" type="xml">
            <form string="View All Assets" class="o_all_assets_wizard">
                <style>
                    .btn-windows {
                        background-color: #E3F2FD !important;
                    }
                    .btn-windows:hover {
                        background-color: #0057D9 !important;
                        color: white !important;
                    }
                    .btn-linux {
                        background-color: #FFF3E0 !important;
                    }
                    .btn-linux:hover {
                        background-color: #E95420 !important;
                        color: white !important;
                    }
                    .btn-macos {
                        background-color: #F5F5F5 !important;
                    }
                    .btn-macos:hover {
                        background-color: #555555 !important;
                        color: white !important;
                    }
                    .btn-cctv {
                        background-color: #E0F2F1 !important;
                    }
                    .btn-cctv:hover {
                        background-color: #009688 !important;
                        color: white !important;
                    }
                    .btn-network {
                        background-color: #F3E5F5 !important;
                    }
                    .btn-network:hover {
                        background-color: #8E24AA !important;
                        color: white !important;
                    }
                    .outline-btn {
                        transition: all 0.3s ease;
                    }
                </style>
                <sheet>
                    <!-- Total Assets Banner -->
                    <div class="alert alert-primary text-center" style="background: linear-gradient(135deg, rgba(52, 152, 219, 0.15) 0%, rgba(41, 128, 185, 0.15) 100%); border: 2px solid rgba(52, 152, 219, 0.3); border-radius: 12px; padding: 30px; margin: 20px 0; box-shadow: 0 2px 8px rgba(52, 152, 219, 0.08);">
                        <h2 style="color: #2980B9; margin: 0; font-size: 16px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;">TOTAL ASSETS</h2>
                        <h1 style="color: #2C3E50; margin: 15px 0 0 0; font-size: 56px; font-weight: 700;">
                            <field name="total_count" readonly="1" nolabel="1" class="oe_inline"/>
                        </h1>
                        <p style="color: #5D6D7B; margin: 10px 0 0 0; font-size: 14px;">Across all categories</p>
                    </div>

                    <!-- Asset Category Cards -->
                    <div class="row" style="margin: 30px 0; display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem;">
                        <!-- Windows Card -->
                        <div style="flex: 1 1 calc(20% - 1rem); min-width: 180px; max-width: 250px;">
                            <div class="card h-100 text-center shadow-sm" style="border: 2px solid #0057D9; border-radius: 12px; transition: transform 0.2s; display: flex; flex-direction: column;">
                                <div class="card-body" style="padding: 30px 20px; display: flex; flex-direction: column; justify-content: space-between; flex: 1;">
                                    <div>
                                        <div style="background: #0057D9; width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                                            <i class="fa fa-windows fa-2x" style="color: white;"/>
                                        </div>
                                        <h4 style="color: #333; font-weight: 600;">Windows</h4>
                                        <h2 style="color: #0057D9; font-weight: 700; font-size: 36px; margin: 15px 0;">
                                            <field name="windows_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <p class="text-muted small">Windows computers and servers</p>
                                    </div>
                                    <button name="action_view_windows" type="object" string="View Windows Assets" class="btn outline-btn btn-windows" style="border: 2px solid #0057D9; color: #0057D9; border-radius: 8px; padding: 10px 20px; width: 100%; margin-top: auto; font-weight: 600;"/>
                                </div>
                            </div>
                        </div>

                        <!-- Linux Card -->
                        <div style="flex: 1 1 calc(20% - 1rem); min-width: 180px; max-width: 250px;">
                            <div class="card h-100 text-center shadow-sm" style="border: 2px solid #E95420; border-radius: 12px; transition: transform 0.2s; display: flex; flex-direction: column;">
                                <div class="card-body" style="padding: 30px 20px; display: flex; flex-direction: column; justify-content: space-between; flex: 1;">
                                    <div>
                                        <div style="background: #E95420; width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                                            <i class="fa fa-linux fa-2x" style="color: white;"/>
                                        </div>
                                        <h4 style="color: #333; font-weight: 600;">Linux</h4>
                                        <h2 style="color: #E95420; font-weight: 700; font-size: 36px; margin: 15px 0;">
                                            <field name="linux_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <p class="text-muted small">Linux computers and servers</p>
                                    </div>
                                    <button name="action_view_linux" type="object" string="View Linux Assets" class="btn outline-btn btn-linux" style="border: 2px solid #E95420; color: #E95420; border-radius: 8px; padding: 10px 20px; width: 100%; margin-top: auto; font-weight: 600;"/>
                                </div>
                            </div>
                        </div>

                        <!-- macOS Card -->
                        <div style="flex: 1 1 calc(20% - 1rem); min-width: 180px; max-width: 250px;">
                            <div class="card h-100 text-center shadow-sm" style="border: 2px solid #555555; border-radius: 12px; transition: transform 0.2s; display: flex; flex-direction: column;">
                                <div class="card-body" style="padding: 30px 20px; display: flex; flex-direction: column; justify-content: space-between; flex: 1;">
                                    <div>
                                        <div style="background: #555555; width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                                            <i class="fa fa-apple fa-2x" style="color: white;"/>
                                        </div>
                                        <h4 style="color: #333; font-weight: 600;">macOS</h4>
                                        <h2 style="color: #555555; font-weight: 700; font-size: 36px; margin: 15px 0;">
                                            <field name="mac_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <p class="text-muted small">Apple Mac computers</p>
                                    </div>
                                    <button name="action_view_mac" type="object" string="View macOS Assets" class="btn outline-btn btn-macos" style="border: 2px solid #555555; color: #555555; border-radius: 8px; padding: 10px 20px; width: 100%; margin-top: auto; font-weight: 600;"/>
                                </div>
                            </div>
                        </div>

                        <!-- CCTV Card -->
                        <div style="flex: 1 1 calc(20% - 1rem); min-width: 180px; max-width: 250px;">
                            <div class="card h-100 text-center shadow-sm" style="border: 2px solid #009688; border-radius: 12px; transition: transform 0.2s; display: flex; flex-direction: column;">
                                <div class="card-body" style="padding: 30px 20px; display: flex; flex-direction: column; justify-content: space-between; flex: 1;">
                                    <div>
                                        <div style="background: #009688; width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                                            <i class="fa fa-video-camera fa-2x" style="color: white;"/>
                                        </div>
                                        <h4 style="color: #333; font-weight: 600;">CCTV Cameras</h4>
                                        <h2 style="color: #009688; font-weight: 700; font-size: 36px; margin: 15px 0;">
                                            <field name="cctv_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <p class="text-muted small">Surveillance cameras and DVR/NVR</p>
                                    </div>
                                    <button name="action_view_cctv" type="object" string="View CCTV Assets" class="btn outline-btn btn-cctv" style="border: 2px solid #009688; color: #009688; border-radius: 8px; padding: 10px 20px; width: 100%; margin-top: auto; font-weight: 600;"/>
                                </div>
                            </div>
                        </div>

                        <!-- Network Card -->
                        <div style="flex: 1 1 calc(20% - 1rem); min-width: 180px; max-width: 250px;">
                            <div class="card h-100 text-center shadow-sm" style="border: 2px solid #8E24AA; border-radius: 12px; transition: transform 0.2s; display: flex; flex-direction: column;">
                                <div class="card-body" style="padding: 30px 20px; display: flex; flex-direction: column; justify-content: space-between; flex: 1;">
                                    <div>
                                        <div style="background: #8E24AA; width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                                            <i class="fa fa-sitemap fa-2x" style="color: white;"/>
                                        </div>
                                        <h4 style="color: #333; font-weight: 600;">Network Devices</h4>
                                        <h2 style="color: #8E24AA; font-weight: 700; font-size: 36px; margin: 15px 0;">
                                            <field name="network_count" readonly="1" nolabel="1"/>
                                        </h2>
                                        <p class="text-muted small">Routers, switches and firewalls</p>
                                    </div>
                                    <button name="action_view_network" type="object" string="View Network Assets" class="btn outline-btn btn-network" style="border: 2px solid #8E24AA; color: #8E24AA; border-radius: 8px; padding: 10px 20px; width: 100%; margin-top: auto; font-weight: 600;"/>
                                </div>
                            </div>
                        </div>
                    </div>


                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open wizard (for menu if needed) -->
    <record id="action_all_assets_wizard" model="ir.actions.act_window">
        <field name="name">View All Assets</field>
        <field name="res_model">asset.all.assets.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="view_id" ref="view_all_assets_wizard_form"/>
    </record>

</odoo>
