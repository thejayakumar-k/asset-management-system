<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_antivirus_ksc_config_form" model="ir.ui.view">
        <field name="name">antivirus.ksc.config.form</field>
        <field name="model">antivirus.ksc.config</field>
        <field name="arch" type="xml">
            <form string="Kaspersky Security Center Configuration" create="false" delete="false">
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Connection Settings">
                            <field name="ksc_url" autocomplete="off"/>
                            <field name="username"/>
                            <field name="password" password="1"/>
                        </group>
                        <group string="Deployment Settings">
                            <field name="package_name"/>
                            <field name="verify_ssl"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_antivirus_ksc_config" model="ir.actions.act_window">
        <field name="name">KSC Configuration</field>
        <field name="res_model">antivirus.ksc.config</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="res_id" eval="False"/>
    </record>

</odoo>
