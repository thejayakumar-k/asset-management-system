<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Storage Volume List View -->
    <record id="view_asset_storage_volume_list" model="ir.ui.view">
        <field name="name">asset.storage.volume.list</field>
        <field name="model">asset.storage.volume</field>
        <field name="arch" type="xml">
            <list string="Storage &amp; File Control" 
                  decoration-info="drive_label == 'system'" 
                  decoration-warning="storage_status == 'warning'"
                  decoration-danger="storage_status == 'critical'">
                <field name="drive_letter" decoration-bf="1"/>
                <field name="drive_label" widget="badge"/>
                <field name="storage_status" widget="badge"
                       decoration-success="storage_status == 'healthy'"
                       decoration-warning="storage_status == 'warning'"
                       decoration-danger="storage_status == 'critical'"/>
                <field name="total_size" widget="float"/>
                <field name="used_space" widget="float"/>
                <field name="free_space" widget="float" decoration-danger="free_space &lt; 5"/>
                <field name="usage_percentage" widget="progressbar"/>
            </list>
        </field>
    </record>

    <!-- Storage Volume Form View -->
    <record id="view_asset_storage_volume_form" model="ir.ui.view">
        <field name="name">asset.storage.volume.form</field>
        <field name="model">asset.storage.volume</field>
        <field name="arch" type="xml">
            <form string="Storage Volume">
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="drive_letter"/>
                            <field name="drive_label"/>
                            <field name="storage_status" widget="badge"
                                   decoration-success="storage_status == 'healthy'"
                                   decoration-warning="storage_status == 'warning'"
                                   decoration-danger="storage_status == 'critical'"/>
                        </group>
                        <group>
                            <field name="total_size"/>
                            <field name="used_space"/>
                            <field name="free_space"/>
                            <field name="usage_percentage" widget="progressbar"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Storage Volume Action -->
    <record id="action_asset_storage_volume" model="ir.actions.act_window">
        <field name="name">Storage &amp; File Control</field>
        <field name="res_model">asset.storage.volume</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
