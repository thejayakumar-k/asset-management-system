<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- =====================================================
         SOFTWARE DEPLOYMENT DASHBOARD - CLIENT ACTION
         ===================================================== -->
    <record id="action_asset_software_dashboard" model="ir.actions.client">
        <field name="name">Software Deployment Dashboard</field>
        <field name="tag">asset_software_dashboard</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>
    <!-- =====================================================
         SOFTWARE LIBRARY - ENHANCED LIST VIEW
         ===================================================== -->
    <record id="view_asset_software_catalog_list_enhanced" model="ir.ui.view">
        <field name="name">asset.software.catalog.list.enhanced</field>
        <field name="model">asset.software.catalog</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <list string="Software Library" create="1" edit="1" delete="1">
                <field name="name"/>
                <field name="version"/>
                <field name="publisher"/>
                <field name="category"/>
                <field name="installer_filename"/>
                <field name="installer_size" string="Size"/>
                <field name="deployment_count" string="Deployments"/>
                <field name="success_rate" widget="progressbar" string="Success Rate"/>
                <field name="create_date" string="Uploaded"/>
            </list>
        </field>
    </record><!-- =====================================================
         SOFTWARE CATALOG - KANBAN VIEW
         ===================================================== -->
    <record id="view_asset_software_catalog_kanban" model="ir.ui.view">
        <field name="name">asset.software.catalog.kanban</field>
        <field name="model">asset.software.catalog</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="version"/>
                <field name="publisher"/>
                <field name="category"/>
                <field name="installer_filename"/>
                <field name="installer_size"/>
                <field name="deployment_count"/>
                <field name="success_rate"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('asset.software.catalog', 'installer_file', record.id.raw_value)" 
                                     alt="Software Icon" class="o_image_64_cover"/>
                            </div>
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <field name="category" widget="badge" 
                                           decoration-success="category == 'security'"
                                           decoration-info="category == 'browser'"
                                           decoration-warning="category == 'office'"
                                           decoration-primary="category == 'development'"/>
                                </div>
                                <ul>
                                    <li class="text-muted">
                                        <i class="fa fa-tag"/> 
                                        <field name="version"/>
                                    </li>
                                    <li class="text-muted">
                                        <i class="fa fa-building"/> 
                                        <field name="publisher"/>
                                    </li>
                                    <li class="text-muted">
                                        <i class="fa fa-file"/> 
                                        <field name="installer_filename"/>
                                    </li>
                                    <li class="text-muted">
                                        <i class="fa fa-hdd-o"/> 
                                        <field name="installer_size"/> MB
                                    </li>
                                </ul>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_partner_categories">
                                        <span class="oe_kanban_list_inline">
                                            <i class="fa fa-rocket"/> 
                                            <field name="deployment_count"/> deployments
                                        </span>
                                    </div>
                                    <div class="oe_kanban_partner_categories">
                                        <field name="success_rate" widget="progressbar"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- =====================================================
         SOFTWARE DEPLOYMENT - ENHANCED LIST VIEW
         ===================================================== -->
    <record id="view_asset_software_deployment_list_enhanced" model="ir.ui.view">
        <field name="name">asset.software.deployment.list.enhanced</field>
        <field name="model">asset.software.deployment</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <list string="Deployment Status" 
                  create="false" 
                  edit="false" 
                  delete="false"
                  decoration-success="status=='installed'" 
                  decoration-danger="status=='failed'" 
                  decoration-info="status in ['downloading','installing']">
                <field name="device_name"/>
                <field name="device_serial"/>
                <field name="software_name"/>
                <field name="software_version"/>
                <field name="status"/>
                <field name="deployed_date"/>
                <field name="completed_date"/>
                <field name="error_message"/>
                <button name="action_retry_deployment"
                        string="Retry"
                        type="object"
                        icon="fa-refresh"
                        invisible="status != 'failed'"/>
            </list>
        </field>
    </record><!-- =====================================================
         SOFTWARE CATALOG - ACTION
         ===================================================== -->
    <record id="action_asset_software_catalog_enhanced" model="ir.actions.act_window">
        <field name="name">Software Library</field>
        <field name="res_model">asset.software.catalog</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_asset_software_catalog_list_enhanced')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_asset_software_catalog_form')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_asset_software_catalog_kanban')})
        ]"/>
        <field name="context">{'search_default_group_category': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Upload your first software installer
            </p>
            <p>
                Add .exe or .msi installers to deploy across your device fleet.
                Support for silent installation with custom flags.
            </p>
        </field>
    </record>
    <!-- =====================================================
         SOFTWARE DEPLOYMENT - ACTION
         ===================================================== -->
    <record id="action_asset_software_deployment_enhanced" model="ir.actions.act_window">
        <field name="name">Deployment Status</field>
        <field name="res_model">asset.software.deployment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1, 'search_default_status_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No deployments yet
            </p>
            <p>
                Software deployments will appear here.
                Go to Software Library to deploy applications.
            </p>
        </field>
    </record>
</odoo>
