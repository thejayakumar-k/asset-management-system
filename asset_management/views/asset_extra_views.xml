<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Locations -->
    <record id="view_asset_location_tree" model="ir.ui.view">
        <field name="name">asset.location.tree</field>
        <field name="model">asset.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="complete_name"/>
            </list>
        </field>
    </record>

    <record id="view_asset_location_form" model="ir.ui.view">
        <field name="name">asset.location.form</field>
        <field name="model">asset.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_asset_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">asset.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Maintenance -->
    <record id="view_asset_maintenance_tree" model="ir.ui.view">
        <field name="name">asset.maintenance.tree</field>
        <field name="model">asset.maintenance</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="maintenance_type"/>
                <field name="request_date"/>
                <field name="maintenance_date"/>
                <field name="cost"/>
                <field name="state" widget="badge" decoration-info="state == 'open'" decoration-warning="state == 'in_progress'" decoration-success="state == 'completed'"/>
            </list>
        </field>
    </record>

    <record id="view_asset_maintenance_form" model="ir.ui.view">
        <field name="name">asset.maintenance.form</field>
        <field name="model">asset.maintenance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="open,in_progress,completed" clickable="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="maintenance_type"/>
                        </group>
                        <group>
                            <field name="request_date"/>
                            <field name="maintenance_date"/>
                            <field name="cost"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_asset_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">asset.maintenance</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Vendors -->
    <record id="view_asset_vendor_tree" model="ir.ui.view">
        <field name="name">asset.vendor.tree</field>
        <field name="model">asset.vendor</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="contact"/>
                <field name="email"/>
            </list>
        </field>
    </record>

    <record id="view_asset_vendor_form" model="ir.ui.view">
        <field name="name">asset.vendor.form</field>
        <field name="model">asset.vendor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Vendor Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="contact"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="sla_details"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assets">
                            <field name="asset_ids" readonly="1">
                                <list>
                                    <field name="asset_code"/>
                                    <field name="asset_name"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_asset_vendor" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="res_model">asset.vendor</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
