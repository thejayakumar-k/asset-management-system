<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ACTION -->
    <record id="action_asset_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">asset.category</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    
     -->

    <!-- KANBAN VIEW (PROFESSIONAL CARDS) -->
    <record id="view_asset_category_kanban" model="ir.ui.view">
        <field name="name">asset.category.kanban</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <kanban class="o_category_kanban">
                <field name="id"/>
                <field name="name"/>
                <field name="description"/>
                <field name="asset_count"/>
                <field name="image_128"/>
                <field name="color"/>
                <field name="icon"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_category_card oe_kanban_global_click oe_kanban_color_#{record.color.raw_value or 1}">
                            <!-- Top Section: Icon Badge and Asset Count -->
                            <div class="category_header">
                                <!-- Icon Badge -->
                                <div class="category_icon_badge">
                                    <t t-if="record.image_128.raw_value">
                                        <img t-att-src="kanban_image('asset.category', 'image_128', record.id.raw_value)"
                                             alt="Category"
                                             class="category_image"/>
                                    </t>
                                    <t t-else="">
                                        <i t-attf-class="fa #{record.icon.value or 'fa-folder'} category_icon"></i>
                                    </t>
                                </div>

                                <!-- Asset Count Badge -->
                                <div class="asset_count_badge">
                                    <div class="count_number"><t t-esc="record.asset_count.value"/></div>
                                    <div class="count_label">Assets</div>
                                </div>
                            </div>

                            <!-- Middle Section: Title and Description -->
                            <div class="category_content">
                                <h3 class="category_title">
                                    <t t-esc="record.name.value"/>
                                </h3>
                                <p class="category_desc" t-if="record.description.value">
                                    <t t-esc="record.description.value"/>
                                </p>
                            </div>

                            <!-- Bottom Section: View Details Button -->
                            <div class="category_footer">
                                <button class="view_details_btn">
                                    View Details
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- LIST VIEW (ENHANCED) -->
    <record id="view_asset_category_list" model="ir.ui.view">
        <field name="name">asset.category.list</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <list string="Asset Categories" sample="1" delete="1">
                <field name="name" decoration-bf="1"/>
                <field name="description" optional="show"/>
                <field name="asset_count" sum="Total Assets"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW (PROFESSIONAL) -->
    <record id="view_asset_category_form" model="ir.ui.view">
        <field name="name">asset.category.form</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <form string="Asset Category" delete="1">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_asset_asset)d" type="action" class="oe_stat_button" icon="fa-laptop" context="{'search_default_category_id': id}">
                            <div class="o_stat_info">
                                <field name="asset_count" class="o_stat_value"/>
                                <span class="o_stat_text">Assets</span>
                            </div>
                        </button>
                    </div>

                    <field name="image_128" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Category Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Laptops, Monitors..."/>
                        </h1>
                    </div>

                    <group>
                        <group string="Configuration" name="config_group">
                            <field name="active" widget="boolean_toggle"/>
                            <field name="color" widget="color_picker"/>
                            <field name="icon" placeholder="e.g. fa-laptop"/>
                        </group>
                        <group string="Usage Metadata" name="meta_group">
                            <label for="asset_count"/>
                            <div class="o_row">
                                <field name="asset_count"/>
                                <span class="text-muted">Registered Items</span>
                            </div>
                        </group>
                    </group>

                    <notebook>
                        <page string="General Description" name="description_page" icon="fa-file-text-o">
                            <field name="description" placeholder="Provide a detailed description for this asset category..." widget="text"/>
                        </page>
                        <page string="Connected Assets" name="assets_page" icon="fa-laptop" invisible="asset_count == 0">
                            <field name="asset_ids" readonly="1" mode="list">
                                <list decoration-info="state == 'draft'" decoration-success="state == 'assigned'" decoration-warning="state == 'maintenance'">
                                    <field name="asset_code"/>
                                    <field name="asset_name"/>
                                    <field name="serial_number"/>
                                    <field name="assigned_employee_id" widget="many2one_avatar_user"/>
                                    <field name="state" widget="badge" decoration-success="state == 'assigned'" decoration-info="state == 'draft'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>