<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="asset_management.DeviceMonitoringDashboard" owl="1">
        <div class="o_device_monitoring">
            <!-- Sidebar: Device List -->
            <div class="dm_sidebar">
                <div class="dm_sidebar_header">
                    <h3>Devices</h3>
                    <div class="input-group input-group-sm mt-2">
                        <input type="text" class="form-control" placeholder="Search devices..." t-on-input="(ev) => this.onSearchInput(ev)"/>
                        <span class="input-group-text"><i class="fa fa-search"/></span>
                    </div>
                </div>
                <div class="dm_device_list">
                    <t t-if="state.assets.length === 0">
                        <div class="text-muted text-center py-3">
                            <i class="fa fa-spinner fa-spin fa-2x mb-2"/>
                            <div>Loading devices...</div>
                        </div>
                    </t>
                    <t t-elif="displayedAssets.length === 0">
                        <div class="text-muted text-center py-3">
                            <i class="fa fa-info-circle fa-2x mb-2"/>
                            <div>No devices for <t t-esc="state.selectedPlatform"/></div>
                            <small t-if="state.assets.length > 0">
                                (Found <t t-esc="state.assets.length"/> total devices)
                            </small>
                        </div>
                    </t>
                    <t t-else="">
                        <t t-foreach="displayedAssets" t-as="asset" t-key="asset.id">
                            <div class="dm_device_card" t-att-class="{active: state.selectedAssetId === asset.id}" t-on-click="() => this.selectAsset(asset.id)">
                                <div class="d-flex justify-content-between">
                                    <span class="dm_device_id" t-esc="asset.asset_code"/>
                                    <span class="dm_status_icon">
                                        <t t-if="asset.is_online"><i class="fa fa-check-circle text-success"/></t>
                                        <t t-else=""><i class="fa fa-times-circle text-danger"/></t>
                                    </span>
                                </div>
                                <div class="dm_device_owner" t-esc="asset.assigned_employee_name || 'Unassigned'"/>
                                <div class="dm_device_location" t-esc="asset.department_name || 'No Department'"/>
                                <div class="dm_device_status_row">
                                    <span class="dm_status_text" t-att-class="asset.is_online ? 'healthy' : 'offline'" t-esc="asset.is_online ? 'Online' : 'Offline'"/>
                                </div>
                            </div>
                        </t>
                    </t>
                </div>
            </div>

            <!-- Main: Metrics Dashboard -->
            <div class="dm_main">
                <t t-if="state.selectedAsset">
                    <div class="dm_header d-flex justify-content-between align-items-center">
                        <div>
                            <h2 t-esc="state.selectedAsset.asset_name"/>
                            <p class="text-muted mb-0">Last synced: <t t-esc="state.selectedAsset.last_agent_sync"/></p>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" t-on-click="() => this.refreshAssetData()">
                                <i class="fa fa-refresh me-1"/> Refresh
                            </button>
                        </div>
                    </div>

                    <div class="dm_metrics_grid">
                        <!-- Common Metrics for Windows, Ubuntu, and macOS -->
                        <t t-if="state.selectedAsset.platform === 'windows' or state.selectedAsset.platform === 'ubuntu' or state.selectedAsset.platform === 'macos'">
                            <!-- CPU Usage -->
                            <div class="dm_metric_card">
                                <div class="dm_metric_header">
                                    <div class="dm_metric_title">
                                        <i class="fa fa-microchip dm_metric_icon"/> CPU Usage
                                    </div>
                                </div>
                                <div class="dm_metric_value_row">
                                    <span class="dm_metric_value" t-esc="state.selectedAsset.cpu_usage.toFixed(1)"/>
                                    <span class="dm_metric_unit">%</span>
                                </div>
                                <div class="dm_progress">
                                    <div class="dm_progress_bar" t-att-style="'width: ' + state.selectedAsset.cpu_usage + '%;'" t-att-class="getProgressBarClass(state.selectedAsset.cpu_usage)"/>
                                </div>
                            </div>

                            <!-- Memory Usage -->
                            <div class="dm_metric_card">
                                <div class="dm_metric_header">
                                    <div class="dm_metric_title">
                                        <i class="fa fa-tasks dm_metric_icon"/> Memory Usage
                                    </div>
                                </div>
                                <div class="dm_metric_value_row">
                                    <span class="dm_metric_value" t-esc="state.selectedAsset.memory_usage.toFixed(1)"/>
                                    <span class="dm_metric_unit">%</span>
                                </div>
                                <div class="dm_progress">
                                    <div class="dm_progress_bar" t-att-style="'width: ' + state.selectedAsset.memory_usage + '%;'" t-att-class="getProgressBarClass(state.selectedAsset.memory_usage)"/>
                                </div>
                            </div>

                            <!-- Storage Usage -->
                            <div class="dm_metric_card">
                                <div class="dm_metric_header">
                                    <div class="dm_metric_title">
                                        <i class="fa fa-hdd-o dm_metric_icon"/> Storage Usage
                                    </div>
                                </div>
                                <div class="dm_metric_value_row">
                                    <span class="dm_metric_value" t-esc="state.selectedAsset.storage_usage.toFixed(1)"/>
                                    <span class="dm_metric_unit">%</span>
                                </div>
                                <div class="dm_progress">
                                    <div class="dm_progress_bar" t-att-style="'width: ' + state.selectedAsset.storage_usage + '%;'" t-att-class="getProgressBarClass(state.selectedAsset.storage_usage)"/>
                                </div>
                            </div>

                            <!-- Battery Level (For Windows, Ubuntu, and macOS) -->
                            <div class="dm_metric_card" t-if="state.selectedAsset.platform === 'windows' or state.selectedAsset.platform === 'ubuntu' or state.selectedAsset.platform === 'macos'">
                                <div class="dm_metric_header">
                                    <div class="dm_metric_title">
                                        <i class="fa fa-battery-half dm_metric_icon"/> Battery Level
                                    </div>
                                </div>
                                <div class="dm_metric_value_row">
                                    <span class="dm_metric_value" t-esc="state.selectedAsset.battery_level.toFixed(1)"/>
                                    <span class="dm_metric_unit">%</span>
                                </div>
                                <div class="dm_progress">
                                    <div class="dm_progress_bar" t-att-style="'width: ' + state.selectedAsset.battery_level + '%;'" t-att-class="getBatteryBarClass(state.selectedAsset.battery_level)"/>
                                </div>
                            </div>
                        </t>

                        <!-- CCTV Specific Metrics -->
                        <t t-if="state.selectedAsset.platform === 'cctv'">
                            <!-- Camera Status -->
                            <div class="dm_metric_card">
                                <div class="dm_metric_header">
                                    <div class="dm_metric_title">
                                        <i class="fa fa-video-camera dm_metric_icon"/> Camera Status
                                    </div>
                                </div>
                                <div class="dm_metric_value_row">
                                    <span class="dm_metric_value" t-att-class="state.selectedAsset.is_online ? 'text-success' : 'text-danger'">
                                        <t t-if="state.selectedAsset.is_online">ONLINE</t>
                                        <t t-else="">OFFLINE</t>
                                    </span>
                                </div>
                            </div>

                            <!-- Recording State -->
                            <div class="dm_metric_card">
                                <div class="dm_metric_header">
                                    <div class="dm_metric_title">
                                        <i class="fa fa-circle dm_metric_icon"/> Recording
                                    </div>
                                </div>
                                <div class="dm_metric_value_row">
                                    <span class="dm_metric_value text-capitalize" t-att-class="getRecordingStatusClass(state.selectedAsset.recording_status)" t-esc="state.selectedAsset.recording_status"/>
                                </div>
                            </div>

                            <!-- Storage Usage -->
                            <div class="dm_metric_card">
                                <div class="dm_metric_header">
                                    <div class="dm_metric_title">
                                        <i class="fa fa-database dm_metric_icon"/> Storage Usage
                                    </div>
                                </div>
                                <div class="dm_metric_value_row">
                                    <span class="dm_metric_value" t-esc="state.selectedAsset.storage_usage.toFixed(1)"/>
                                    <span class="dm_metric_unit">%</span>
                                </div>
                                <div class="dm_progress">
                                    <div class="dm_progress_bar" t-att-style="'width: ' + state.selectedAsset.storage_usage + '%;'" t-att-class="getProgressBarClass(state.selectedAsset.storage_usage)"/>
                                </div>
                            </div>

                            <!-- Motion Events -->
                            <div class="dm_metric_card">
                                <div class="dm_metric_header">
                                    <div class="dm_metric_title">
                                        <i class="fa fa-eye dm_metric_icon"/> Motion Detected
                                    </div>
                                </div>
                                <div class="dm_metric_value_row">
                                    <span class="dm_metric_value" t-att-class="getMotionDetectedClass(state.selectedAsset.motion_detected)">
                                        <t t-if="state.selectedAsset.motion_detected">YES</t>
                                        <t t-else="">NO</t>
                                    </span>
                                </div>
                                <div class="mt-2 small text-muted">
                                    Last: <t t-esc="state.selectedAsset.last_motion_time"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <div class="h-100 d-flex flex-column justify-content-center align-items-center text-muted">
                        <i class="fa fa-laptop fa-5x mb-3"/>
                        <h3>Select a device to view monitoring data</h3>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
