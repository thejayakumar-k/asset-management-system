<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="asset_management.AssetListDashboard" owl="1">
        <!-- Dashboard cards removed -->
    </t>

    <t t-name="asset_management.KanbanRenderer" t-inherit="web.KanbanRenderer" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_kanban_renderer')]" position="before">
            <t t-if="props.list.context.is_all_assets_view and !props.list.isX2Many">
                <AssetListDashboard list="props.list"/>
            </t>
        </xpath>
    </t>

    <t t-name="asset_management.ListRenderer" t-inherit="web.ListRenderer" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_list_renderer')]" position="before">
            <t t-if="props.list.context.is_all_assets_view and !props.list.isX2Many">
                <AssetListDashboard list="props.list"/>
            </t>
        </xpath>
    </t>
</templates>
