<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_check_network_device_status" model="ir.cron">
            <field name="name">Network: Check Device Status</field>
            <field name="model_id" ref="model_snmp_monitor_service"/>
            <field name="state">code</field>
            <field name="code">model.check_all_devices()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
