<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- =====================================================
             SCHEDULED ACTION: Check Camera Status
             Runs every 10 minutes to check all active cameras
             ===================================================== -->
        <record id="ir_cron_check_camera_status" model="ir.cron">
            <field name="name">CCTV: Check Camera Status</field>
            <field name="model_id" ref="model_camera_monitor_service"/>
            <field name="state">code</field>
            <field name="code">model.check_all_cameras()</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
