<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Auto Discovery Scan every 1 minute -->
        <record id="ir_cron_network_auto_discovery" model="ir.cron">
            <field name="name">Network: Auto Discovery Scan</field>
            <field name="model_id" ref="model_network_discovery_service"/>
            <field name="state">code</field>
            <field name="code">model.run_discovery()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Auto Setup on New Database - runs daily, auto-creates config if missing -->
        <record id="cron_network_discovery_startup" model="ir.cron">
            <field name="name">Network: Auto Setup on New Database</field>
            <field name="model_id" ref="model_network_discovery_service"/>
            <field name="state">code</field>
            <field name="code">model._auto_setup_on_startup()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="priority">1</field>
        </record>

    </data>
</odoo>