            <field name="icon">fa-laptop</field>
        </record>

        <record id="category_laptop" model="asset.category">
            <field name="name">Laptop</field>
            <field name="code">LAP</field>
            <field name="active" eval="True"/>
            <field name="color">8</field>
            <field name="icon">fa-laptop</field>
        </record>

        <record id="category_monitor" model="asset.category">
            <field name="name">Monitor</field>
            <field name="code">MON</field>
            <field name="active" eval="True"/>
            <field name="color">7</field>
            <field name="icon">fa-desktop</field>
        </record>

    </data>
</odoo>
