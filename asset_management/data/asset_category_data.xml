<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- ==========================================
             PREDEFINED ASSET CATEGORIES
             ========================================== -->

        <record id="category_cctv" model="asset.category">
            <field name="name">CCTV Camera</field>
            <field name="description">CCTV surveillance cameras and monitoring equipment</field>
            <field name="active" eval="True"/>
            <field name="color">5</field>
            <field name="icon">fa-video-camera</field>
        </record>

        <record id="category_nvr" model="asset.category">
            <field name="name">NVR/DVR</field>
            <field name="description">Network Video Recorder and Digital Video Recorder systems</field>
            <field name="active" eval="True"/>
            <field name="color">3</field>
            <field name="icon">fa-hdd-o</field>
        </record>

        <record id="category_router" model="asset.category">
            <field name="name">Router</field>
            <field name="code">RTR</field>
            <field name="active" eval="True"/>
            <field name="color">6</field>
            <field name="icon">fa-share-alt</field>
        </record>

        <record id="category_switch" model="asset.category">
            <field name="name">Switch</field>
            <field name="code">SWT</field>
            <field name="active" eval="True"/>
            <field name="color">2</field>
            <field name="icon">fa-server</field>
        </record>

        <record id="category_firewall" model="asset.category">
            <field name="name">Firewall</field>
            <field name="code">FWL</field>
            <field name="active" eval="True"/>
